# Tham chiếu biến cần nhập trên Render (Dashboard hoặc lúc tạo Blueprint).
# Không commit file chứa secret thật.

# --- Backend (coregate-backend) — sync: false trên Render ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# Sau khi có URL thật từ Render:
VNPAY_RETURN_URL=https://coregate-ui.onrender.com/payment-callback
VNPAY_IPN_URL=https://coregate-backend.onrender.com/api/webhooks/vnpay

# --- Tự gắn bởi render.yaml (không cần nhập tay) ---
# DB_HOST, DB_PORT, DB_NAME, DB_USERNAME, DB_PASSWORD  ← từ Postgres coregate-db
# ALLOWED_ORIGINS  ← RENDER_EXTERNAL_URL của coregate-ui
# DOWNLOAD_PUBLIC_BASE_URL  ← RENDER_EXTERNAL_URL của coregate-backend
# API_BASE_URL (UI)  ← RENDER_EXTERNAL_URL của coregate-backend
